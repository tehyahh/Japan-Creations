<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Series</title>
    <style>
        :root {
            --cyber-red: #ff003c;
            --cyber-orange: #fcee0a;
            --dark-bg: #050505;
        }

        body {
            background-color: var(--dark-bg);
            background-image: linear-gradient(rgba(255, 0, 60, 0.05) 50%, rgba(0, 0, 0, 0.3) 50%), 
                              linear-gradient(90deg, rgba(255, 0, 0, 0.08), rgba(255, 0, 0, 0.02), rgba(255, 0, 0, 0.08));
            background-size: 100% 4px, 3px 100%;
            color: #fff;
            font-family: 'Courier New', Courier, monospace;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }

        .container { max-width: 1100px; width: 100%; }

        /* --- HEADER --- */
        .sketch-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            padding: 20px 0 10px 0;
        }

        .logo-text {
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: -4px;
            margin: 0;
            color: var(--cyber-red);
            text-shadow: 3px 3px 0px rgba(255, 0, 60, 0.3);
        }

        .sub-logo { font-size: 0.75rem; letter-spacing: 4px; font-weight: bold; margin-top: 5px; }

        .nav-links { display: flex; gap: 40px; margin-bottom: 10px; }
        .nav-item { 
            color: #fff; text-decoration: none; font-weight: bold; cursor: pointer; 
            background: none; border: none; font-family: inherit; font-size: 1rem;
            transition: 0.2s;
        }
        .nav-item:hover, .nav-item.active { color: var(--cyber-red); transform: skew(-10deg); text-shadow: 0 0 8px var(--cyber-red); }

        .search-bar {
            border: 2px solid var(--cyber-red);
            padding: 5px 15px;
            display: flex;
            align-items: center;
            background: rgba(255, 0, 60, 0.1);
        }

        .search-bar input { background: transparent; border: none; color: var(--cyber-orange); outline: none; margin-left: 8px; width: 120px; }

        .double-divider {
            border-top: 3px solid var(--cyber-red);
            border-bottom: 1px solid var(--cyber-orange);
            height: 6px;
            margin: 10px 0 50px 0;
        }

        /* --- GRID --- */
        .anime-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            min-height: 500px;
        }

        .chip-card { display: flex; flex-direction: column; align-items: center; cursor: pointer; animation: glitchIn 0.3s ease; }

        @keyframes glitchIn {
            0% { opacity: 0; transform: scale(0.9); }
            100% { opacity: 1; transform: scale(1); }
        }

        .chip-outer {
            width: 200px; height: 250px; background: var(--cyber-red);
            clip-path: polygon(20% 0%, 100% 0, 100% 80%, 80% 100%, 0 100%, 0% 20%);
            display: flex; align-items: center; justify-content: center; transition: 0.3s;
        }

        .chip-inner {
            width: 192px; height: 242px; background: #000; clip-path: inherit; overflow: hidden; position: relative;
        }

        .chip-img { width: 100%; height: 100%; object-fit: cover; opacity: 0.6; filter: grayscale(100%); transition: 0.4s; }

        .chip-card:hover .chip-img {
            opacity: 1; filter: grayscale(0%) sepia(30%) hue-rotate(-50deg); transform: scale(1.1);
        }

        .label-box {
            margin-top: 15px; width: 200px; height: 40px; border-left: 5px solid var(--cyber-red);
            background: rgba(255, 0, 60, 0.1); display: flex; align-items: center; justify-content: center;
            font-weight: bold; color: var(--cyber-red); text-align: center; font-size: 0.75rem;
        }

        /* --- MODAL (Matches Screenshot) --- */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); display: none; justify-content: center; align-items: center; z-index: 2000;
        }

        .modal-content {
            background: #2a0a0a; width: 850px; max-height: 90vh; border-radius: 20px;
            overflow-y: auto; position: relative; border: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 40px;
        }

        .modal-header { padding: 20px; }
        .back-btn {
            background: var(--cyber-orange); color: #000; border: none;
            padding: 8px 25px; border-radius: 20px; font-weight: bold; cursor: pointer;
            text-transform: uppercase; font-size: 0.9rem;
        }

        .video-box {
            width: 90%; height: 380px; background: #000; margin: 0 auto;
            display: flex; justify-content: center; align-items: center;
            border: 2px solid rgba(255,255,255,0.05);
        }

        .info-section { padding: 25px 45px; }
        .info-title { font-size: 1.8rem; font-weight: bold; color: #fff; margin-bottom: 5px; }
        .info-row { margin-bottom: 15px; line-height: 1.6; color: #ccc; }
        .info-row b { color: #fff; display: block; margin-top: 12px; margin-bottom: 2px; }

        .divider { border-bottom: 1px solid rgba(255,255,255,0.2); margin: 30px 0; position: relative; }
        .season-label {
            position: absolute; right: 0; top: -15px; background: #2a0a0a;
            border: 1px solid #fff; padding: 4px 20px; font-size: 0.8rem;
        }

        .ep-list { padding: 0 45px; list-style: none; margin: 0; }
        .ep-item { padding: 12px 0; color: #bbb; cursor: pointer; transition: 0.2s; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .ep-item:hover { color: var(--cyber-red); padding-left: 10px; }

        .empty-state { grid-column: 1 / -1; text-align: center; color: var(--cyber-orange); margin-top: 100px; font-size: 1.2rem; }
    </style>
</head>
<body>

    <div class="modal-overlay" id="modalOverlay">
        <div class="modal-content">
            <div class="modal-header">
                <button class="back-btn" id="closeModal">BACK ◀</button>
            </div>
            
            <div class="video-box" id="modalVideoContainer">
                </div>

            <div class="info-section">
                <div id="modalTitle" class="info-title"></div>
                <div class="info-row">
                    <b>SERIES:</b> <span id="modalSeries"></span>
                    <b>RATING:</b> <span id="modalRating"></span>
                    <b>SYNOPSIS:</b> <span id="modalSynopsis"></span>
                </div>

                <div class="divider">
                    <div class="season-label">SEASON 1</div>
                </div>
            </div>

            <ul class="ep-list" id="epList"></ul>
        </div>
    </div>

    <div class="container">
        <header class="sketch-header">
            <div class="logo-area">
                <h1 class="logo-text">J-ANIME</h1>
                <div class="sub-logo">JAPANESE ANIME</div>
            </div>
            <nav class="nav-links">
                <button class="nav-item" onclick="navigate('HOME')">HOME</button>
                <button class="nav-item" onclick="navigate('MOVIES')">MOVIES</button>
                <button class="nav-item active" onclick="navigate('SERIES')">SERIES</button>
                <button class="nav-item" onclick="navigate('AUTHORS')">AUTHORS</button>
                <button class="nav-item" onclick="navigate('ABOUT')">ABOUT</button>
            </nav>
            <div class="search-bar">
                <span>⚠</span>
                <input type="text" id="searchInput" placeholder="SEARCH">
            </div>
        </header>

        <div class="double-divider"></div>
        <main class="anime-grid" id="grid-container"></main>
    </div>

    <script>
        const grid = document.getElementById('grid-container');
        const modal = document.getElementById('modalOverlay');
        const closeBtn = document.getElementById('closeModal');
        const searchInput = document.getElementById('searchInput');
        const videoContainer = document.getElementById('modalVideoContainer');

        // --- COMPLETE DATABASE (9 ANIME) ---
        const animeData = [
            { 
                name: "JUJUTSU KAISEN", 
                img: "JJK..jpg", 
                videoUrl: "Jujutsu Kaisen.mp4", 
                series: "Jujutsu Kaisen", 
                rating: "8.7/10", 
                synopsis: "High school student Yuji Itadori joins a secret organization of Jujutsu Sorcerers to kill a powerful Curse named Ryomen Sukuna.", 
                eps: ["EPISODE 1", "EPISODE 2", "EPISODE 3"] 
            },
            { 
                name: "DEMON SLAYER", 
                img: "DS.jpg", 
                videoUrl: "Demon Slayer.mp4", 
                series: "Kimetsu no Yaiba", 
                rating: "8.6/10", 
                synopsis: "Tanjiro becomes a demon slayer to save his sister and avenge his family.", 
                eps: ["EPISODE 1", "EPISODE 2", "EPISODE 3", "EPISODE 4"] 
            },
            { 
                name: "CHAINSAWMAN", 
                img: "CM.jpg", 
                videoUrl: "Chainsaw Man.mp4", 
                series: "Chainsaw Man", 
                rating: "8.5/10", 
                synopsis: "Denji merges with his chainsaw pet to become a devil hunter.", 
                eps: ["EPISODE 1", "EPISODE 2"] 
            },
            { 
                name: "SAIKI K.", 
                img: "SK.jpg", 
                videoUrl: "Saiki.mp4", 
                series: "The Disastrous Life of Saiki K.", 
                rating: "8.4/10", 
                synopsis: "A powerful psychic tries to lead a normal life despite his chaotic classmates.", 
                eps: ["EPISODE 1", "EPISODE 2", "EPISODE 3"] 
            },
            { 
                name: "SPY X FAMILY", 
                img: "SF.jpg", 
                videoUrl: "SpyxFamily.mp4", 
                series: "Spy x Family", 
                rating: "8.6/10", 
                synopsis: "A spy creates a fake family to fulfill a mission, unaware of his family's secrets.", 
                eps: ["EPISODE 1", "EPISODE 2"] 
            },
            { 
                name: "KAGUYA-SAMA: LOVE IS WAR", 
                img: "LW.jpg", 
                videoUrl: "Kaguya-sama.mp4", 
                series: "Kaguya-sama wa Kokurasetai", 
                rating: "8.5/10", 
                synopsis: "Two geniuses try to trick the other into confessing their love first.", 
                eps: ["EPISODE 1", "EPISODE 2"] 
            },
            { 
                name: "FRIEREN", 
                img: "Frieren.jpg", 
                videoUrl: "Frieren.mp4", 
                series: "Frieren: Beyond Journey's End", 
                rating: "9.1/10", 
                synopsis: "An immortal elf mage explores the meaning of life after her quest ends.", 
                eps: ["EPISODE 1", "EPISODE 2", "EPISODE 3"] 
            },
            { 
                name: "HAIKYUU", 
                img: "haikyu.jpg", 
                videoUrl: "Haikyuu.mp4", 
                series: "Haikyuu!!", 
                rating: "8.7/10", 
                synopsis: "A short boy aims for volleyball greatness in high school.", 
                eps: ["EPISODE 1", "EPISODE 2", "EPISODE 3"] 
            },
            { 
                name: "SK8 THE INFINITY", 
                img: "sk8.jpg", 
                videoUrl: "SK8.mp4", 
                series: "SK8 the Infinity", 
                rating: "8.0/10", 
                synopsis: "Skaters compete in a secret underground race in an abandoned mine.", 
                eps: ["EPISODE 1", "EPISODE 2"] 
            }
        ];

        // --- CORE FUNCTIONS ---

        function renderAnime(data) {
            grid.innerHTML = "";
            if (data.length === 0) {
                grid.innerHTML = `<div class="empty-state">[NO MATCHES FOUND]</div>`;
                return;
            }

            data.forEach((anime) => {
                const card = document.createElement('div');
                card.className = 'chip-card';
                card.innerHTML = `
                    <div class="chip-outer">
                        <div class="chip-inner"><img src="${anime.img}" alt="${anime.name}" class="chip-img"></div>
                    </div>
                    <div class="label-box">${anime.name}</div>
                `;
                
                card.onclick = () => {
                    // Text
                    document.getElementById('modalTitle').innerText = anime.name;
                    document.getElementById('modalSeries').innerText = anime.series;
                    document.getElementById('modalRating').innerText = anime.rating;
                    document.getElementById('modalSynopsis').innerText = anime.synopsis;

                    // Video
                    if (anime.videoUrl.includes('youtube.com')) {
                        videoContainer.innerHTML = `<iframe width="100%" height="100%" src="${anime.videoUrl}" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
                    } else if (anime.videoUrl !== "") {
                        videoContainer.innerHTML = `<video width="100%" height="100%" controls><source src="${anime.videoUrl}" type="video/mp4"></video>`;
                    } else {
                        // Default green box placeholder
                        videoContainer.innerHTML = `<div style="width:100%; height:100%; background:#00ff00; display:flex; justify-content:center; align-items:center;"><div style="font-size:80px; color:#fff; cursor:pointer;">▶</div></div>`;
                    }

                    // Episode List
                    const epList = document.getElementById('epList');
                    epList.innerHTML = "";
                    anime.eps.forEach(e => {
                        const li = document.createElement('li');
                        li.className = "ep-item";
                        li.innerText = e;
                        epList.appendChild(li);
                    });

                    modal.style.display = 'flex';
                };
                grid.appendChild(card);
            });
        }

        function navigate(page) {
            document.querySelectorAll('.nav-item').forEach(btn => btn.classList.remove('active'));
            if(page === 'SERIES') {
                document.querySelector('.nav-item:nth-child(3)').classList.add('active');
                renderAnime(animeData);
            } else {
                grid.innerHTML = `<div class="empty-state">[ACCESS DENIED: ${page} DATABASE EMPTY]</div>`;
            }
        }

        // --- SEARCH LOGIC ---
        searchInput.oninput = (e) => {
            const term = e.target.value.toLowerCase();
            const filtered = animeData.filter(a => a.name.toLowerCase().includes(term));
            renderAnime(filtered);
        };

        // --- CLOSE MODAL ---
        closeBtn.onclick = () => {
            modal.style.display = 'none';
            videoContainer.innerHTML = ""; // Stop video playback
        };

        window.onclick = (e) => { 
            if (e.target == modal) {
                modal.style.display = 'none';
                videoContainer.innerHTML = ""; 
            }
        };

        
        renderAnime(animeData);
    </script>
</body>
</html>
